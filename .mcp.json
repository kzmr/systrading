{
  "mcpServers": {
    "gmo-coin": {
      "type": "stdio",
      "command": "node",
      "args": ["mcp-gmo-coin/dist/index.js"],
      "env": {
        "GMO_API_KEY": "",
        "GMO_API_SECRET": ""
      }
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "."
      ],
      "env": {}
    }
  }
}
